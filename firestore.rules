rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'darshanwala894@gmail.com' || 
        request.auth.token.email == 'auriicsservices@gmail.com' ||
        request.auth.token.email == 'mayur.jungi@aurrum.co' ||
        getUserData().get('role', 'none') in ['admin', 'team_leader', 'developer']
      );
    }

    function isTeamLeader() {
      return isSignedIn() && getUserData().get('role', 'none') == 'team_leader';
    }

    function isTeamMember() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        isAdmin() || (user.role in ['team_leader', 'recruiter'] && user.get('isArchived', false) == false)
      );
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      function isValidUser(data) {
        return data.uid is string && 
               data.email is string && 
               data.role in ['admin', 'team_leader', 'recruiter', 'developer'];
      }

      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Support updating own profile or status/readCursors
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Invitations for pre-registration
    match /invitations/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Candidate Collection Rules
    match /candidates/{candidateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Notifications Collection Rules
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all'
        )
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all'
        )
      );
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // Training CV Collection Rules
    match /training_cvs/{cvId} {
      allow read, write: if isAdmin();
    }

    // Activity Logs Collection Rules
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Chat Message Rules (Global)
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Direct Message Rules (DM)
    match /direct_messages/{messageId} {
      // Allow read if user is sender, recipient, or in participants list
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        resource.data.get('participants', []).hasAny([request.auth.uid])
      );
      
      // Allow create if user is sender and part of participants
      allow create: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.get('participants', []).hasAny([request.auth.uid])
      );
      
      allow delete: if isAdmin();
    }

    // Typing State Rules
    match /typing_states/{conversationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Help Section Rules
    match /help_sections/{sectionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Consolidated Invoices Rules
    match /consolidated_invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isAdmin() || 
        getUserData().get('role', 'none') == 'client'
      );
    }

    // Candidate Invoice Rules
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isAdmin() || 
        getUserData().get('role', 'none') == 'client'
      );
    }

    // Global Settings Rules
    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
