{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && node -e \"const fs = require('fs'); fs.copyFileSync('metadata.json', 'dist/metadata.json'); if (fs.existsSync('firebase-applet-config.json')) fs.copyFileSync('firebase-applet-config.json', 'dist/firebase-applet-config.json');\"",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
