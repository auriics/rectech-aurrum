{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users with different access levels",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "recruiter", "team_leader"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Candidate": {
      "title": "Candidate",
      "description": "Resume data and parsing results",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "summary": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "array" },
        "education": { "type": "array" },
        "domain": { "type": "string", "description": "Professional field like Tech, Finance, Marketing" },
        "rawText": { "type": "string" },
        "fileData": { "type": "string", "description": "Base64 encoded file or URL" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "isShortlisted": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "uploadedBy": { "type": "string" },
        "notes": { "type": "string", "description": "Internal recruiter notes and comments" },
        "notesUpdatedBy": { "type": "string" },
        "followUpNote": { "type": "string" },
        "followUpDate": { "type": "string" },
        "followUpUpdatedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "uploadedBy", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Internal team communication messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "createdAt"]
    },
    "TrainingCV": {
      "title": "TrainingCV",
      "description": "Gold-standard CVs for manual extraction training",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "linkedin": { "type": "string" },
        "summary": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "array" },
        "education": { "type": "array" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "ats_score": { "type": "number" },
        "missing_keywords": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "uploadedBy", "createdAt"]
    },
    "DirectMessage": {
      "title": "DirectMessage",
      "description": "1-on-1 team member messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "recipientId": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "file": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "data": { "type": "string" },
            "type": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "recipientId", "conversationId", "createdAt"]
    },
    "HelpSection": {
      "title": "HelpSection",
      "description": "Content for the Help Center/User Guide",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" },
        "roles": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "order"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Global team chat messages"
    },
    "/direct_messages/{messageId}": {
      "schema": "DirectMessage",
      "description": "Private team communications"
    },
    "/training_cvs/{cvId}": {
      "schema": "TrainingCV",
      "description": "Stored examples for resume parsing"
    },
    "/candidates/{candidateId}": {
      "schema": "Candidate",
      "description": "Processed resume documents"
    },
    "/help_sections/{sectionId}": {
      "schema": "HelpSection",
      "description": "Help center documentation sections"
    }
  }
}
